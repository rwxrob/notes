#!/usr/bin/env bash
# Scan GH Archive via BigQuery for active knowledge/PKM repos.
# Results are filtered and saved to FOLLOWING/gharchive.tsv.
# Usage: ./scan-gharchive [YYYYMM]
#   Default period: last calendar month

_year=$(date +%Y)
_month=$(date +%m)
if [ "$_month" -eq 1 ]; then
  _year=$((_year - 1)); _month=12
else
  _month=$((_month - 1))
fi
_default=$(printf "%04d%02d" "$_year" "$_month")
period="${1:-$_default}"
dir="$(dirname "$0")"
out="$dir/gharchive.tsv"
tmp=$(mktemp)

bq query \
  --project_id=rwxrob-discovery \
  --use_legacy_sql=false \
  --format=csv \
  --max_rows=999999 \
"SELECT DISTINCT repo.name, COUNT(*) as events
FROM \`githubarchive.month.${period}\`
WHERE (
  LOWER(repo.name) LIKE '%/notes-%'
  OR LOWER(repo.name) LIKE '%/zet-%'
  OR LOWER(repo.name) LIKE '%/keg-%'
  OR LOWER(repo.name) LIKE '%/kb-%'
  OR LOWER(repo.name) LIKE '%/dg-%'
  OR LOWER(repo.name) LIKE '%/braindump%'
  OR LOWER(repo.name) LIKE '%-roam%'
  OR LOWER(repo.name) LIKE '%-denote%'
  OR LOWER(repo.name) LIKE '%memex%'
  OR REGEXP_EXTRACT(repo.name, r'/(.+)$') IN ('notes','zet','keg','kb','knowledge','thoughts','ideas','braindump','org','gtd','denote','second-brain','memex')
)
AND type = 'PushEvent'
GROUP BY repo.name
ORDER BY events DESC" > "$tmp"

# Filter out non-PKM repos (apps, APIs, tools, courses, etc.)
grep -viE '[-/](app|api|backend|back-end|frontend|front-end|service|server|client|web|webapp|site|cli|plugin|extension|bot|agent|sdk|lib|library|manager|management|system|application|taking|sharing|share|react|vue|angular|flutter|android|ios|mobile|demo|tutorial|course|learning|study|homework|school|class|assignment|project|scaffold|template|boilerplate|starter|clone|todo|practice|test|upload|download|deploy|docker|cloud|micro|keeper|saver|hub|viewer|ui|summarizer|rag|portal|platform|exporter|generator|chatbot|notif|nest|core|maker|miniapp|hugo|quartz|contracts|mcp|front|images|list|sync|lens|yaml|portfolio|crud|backup|dashboard|board|roaming|calculator|settlement|zotero|nvim|assment|blog|page)' "$tmp" \
  | grep -vi '\.github\.io' \
  > "$out"

rm "$tmp"

# Remove any repos already discarded from previous reviews
if [ -s "$dir/discarded" ]; then
  grep -vFf "$dir/discarded" "$out" > "$out.tmp" && mv "$out.tmp" "$out"
fi

echo "Saved $out ($(grep -c '' "$out") results)"
